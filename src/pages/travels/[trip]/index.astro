---
import { getTripRegions } from "../../../lib/travels"
import Layout from "../../../layouts/Layout.astro"
import { Image } from "astro:assets"

export async function getStaticPaths() {
  return [
    {
      params: { trip: "digital-nomad" },
      props: { trippy: "" },
    },
  ]
}

const { trip } = Astro.params
const regions = getTripRegions(trip)
---

<Layout title="Home">
  {
    regions.map((region) => (
      <div class="">
        <h2 class="text-2xl">{region.name}</h2>
        <ul class="flex flex-wrap justify-evenly">
          {region.pictures.map((picture) => (
            <li class="">
              <a
                href={`/travels/${picture.trip}/${picture.region}/${picture.filename}`}
              >
                <Image
                  src={picture.import()}
                  alt={picture.filename}
                  width="300"
                />
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</Layout>
